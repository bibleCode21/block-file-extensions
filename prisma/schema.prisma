generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ExtensionRuleSet {
  id                  String  @id @default(uuid()) @db.Uuid
  key                 String  @unique @map("rule_set_key")
  name                String
  description         String?
  isDefault           Boolean @default(false) @map("is_default")
  maxCustomExtensions    Int @default(200) @map("max_custom_extensions")
  maxExtensionNameLength Int @default(20) @map("max_extension_name_length")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  extensions Extension[]

  @@map("extension_rule_sets")
}

model Extension {
  id        String @id @default(uuid()) @db.Uuid
  ruleSetId String @map("rule_set_id") @db.Uuid

  extensionName String  @map("extension_name")
  isFixed       Boolean @map("is_fixed")
  enabled       Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  ruleSet ExtensionRuleSet @relation(fields: [ruleSetId], references: [id])

  @@unique([ruleSetId, extensionName])
  @@map("extensions")
}
