generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ExtensionPolicy {
  id        String   @id @default(uuid()) @db.Uuid @map("id")
  name      String   @map("name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  extensions Extension[] @relation("PolicyExtensions")

  @@map("extension_policies")
}

model Extension {
  id            String   @id @default(uuid()) @db.Uuid @map("id")
  policyId      String   @db.Uuid @map("policy_id")
  extensionName String   @map("extension_name")
  isFixed       Boolean  @map("is_fixed")
  enabled       Boolean  @default(true) @map("enabled")
  createdAt     DateTime @default(now()) @map("created_at")

  policy ExtensionPolicy
    @relation("PolicyExtensions", fields: [policyId], references: [id])

  @@unique([policyId, extensionName])
  @@map("extensions")
}